# ============================================================
# .gitignore — Archivos y carpetas que NO se suben al repo
# ============================================================

# Entorno y configuraciones sensibles
.env
config/config.local.php

# Firebase credentials (NO subir al repositorio)
/storage/app/firebase-credentials.json
!/storage/app/.gitkeep

# Logs y archivos temporales
storage/logs/*
!storage/logs/.gitkeep

storage/backups/*
!storage/backups/.gitkeep

storage/sessions/*
!storage/sessions/.gitkeep

# Uploads de usuarios
public/uploads/*

# Dependencias del proyecto (cada quien corre composer install)
/vendor/

# Sistema
.DS_Store
Thumbs.db
*.log

# Datos de MySQL local (no subir)
storage/mysql_data/

# No ignorar SQLs de base de datos
!Base_taller.sql
!stored_procedures.sql
!procedures.sql

# Instalador
install.php
